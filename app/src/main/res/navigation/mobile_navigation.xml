<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_login">

    <fragment
        android:id="@+id/nav_login"
        android:name="com.in.trabajo_final_mobil_2026.ui.login.LoginFragment"
        android:label="@string/menu_login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_reparacion"
            app:destination="@id/nav_reparacion"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_reparacion"
        android:name="com.in.trabajo_final_mobil_2026.ui.reparacion.ReparacionFragment"
        android:label="@string/menu_reparacion"
        tools:layout="@layout/fragment_reparacion" />
    <fragment
        android:id="@+id/nav_usuario"
        android:name="com.in.trabajo_final_mobil_2026.ui.usuario.UsuarioFragment"
        android:label="@string/Usuarios"
        tools:layout="@layout/fragment_usuario" />
    <fragment
        android:id="@+id/nav_stock"
        android:name="com.in.trabajo_final_mobil_2026.ui.stock.StockFragment"
        android:label="@string/Stock"
        tools:layout="@layout/fragment_stock" />
</navigation>
